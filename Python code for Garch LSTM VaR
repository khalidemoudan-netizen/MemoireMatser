import pandas as pd
import numpy as np
import warnings
warnings.filterwarnings("ignore")

from arch import arch_model

# ------------------------------------------------------------
# 1. Load prepared data and Step 3 results
# ------------------------------------------------------------

DATA_FILE = "MASI_prepared_data.xlsx"
GARCH_RESULTS_FILE = "Step3_GARCH_family_results.xlsx"

df = pd.read_excel(DATA_FILE, engine="openpyxl")
df["Date"] = pd.to_datetime(df["Date"])
df = df.sort_values("Date").reset_index(drop=True)

ic_table = pd.read_excel(
    GARCH_RESULTS_FILE,
    sheet_name="AIC_BIC_Table",
    engine="openpyxl"
)

returns = df["ret"].astype(float)

TRAIN_RATIO = 0.80
split_idx = int(len(df) * TRAIN_RATIO)

returns_train = returns.iloc[:split_idx]
returns_test = returns.iloc[split_idx:]

print("Train observations:", len(returns_train))
print("Test observations :", len(returns_test))


# ------------------------------------------------------------
# 2. Select best model by family using BIC
# ------------------------------------------------------------

best_by_family = {}

for family in ["GARCH", "EGARCH", "GJR-GARCH"]:
    sub = ic_table[ic_table["Family"] == family].copy()
    sub = sub.dropna(subset=["BIC"])
    sub = sub.sort_values("BIC")

    if len(sub) == 0:
        raise ValueError(f"No valid model found for {family}")

    best_row = sub.iloc[0]
    best_by_family[family] = best_row

    print("\nBest", family, "model:")
    print(best_row[["Model", "p", "o", "q", "Distribution", "AIC", "BIC"]])


# ------------------------------------------------------------
# 3. Function to estimate GARCH-family models
# ------------------------------------------------------------

def fit_garch_model(returns, family, p, o, q, dist):
    """
    Estimate GARCH, EGARCH or GJR-GARCH model.
    """

    if family == "GARCH":
        model = arch_model(
            returns,
            mean="Constant",
            vol="GARCH",
            p=int(p),
            o=0,
            q=int(q),
            dist=dist,
            rescale=False
        )

    elif family == "EGARCH":
        model = arch_model(
            returns,
            mean="Constant",
            vol="EGARCH",
            p=int(p),
            o=int(o),
            q=int(q),
            dist=dist,
            rescale=False
        )

    elif family == "GJR-GARCH":
        model = arch_model(
            returns,
            mean="Constant",
            vol="GARCH",
            p=int(p),
            o=int(o),
            q=int(q),
            dist=dist,
            rescale=False
        )

    else:
        raise ValueError("Unknown model family.")

    result = model.fit(disp="off", show_warning=False)

    return result


# ------------------------------------------------------------
# 4. Estimate best model of each family on the in-sample period
# ------------------------------------------------------------

fitted_family_models = {}

for family, row in best_by_family.items():

    result = fit_garch_model(
        returns=returns_train,
        family=family,
        p=row["p"],
        o=row["o"],
        q=row["q"],
        dist=row["Distribution"]
    )

    fitted_family_models[family] = result

    print("\n============================================================")
    print(f"Summary of best {family} model")
    print("============================================================")
    print(result.summary())


# ------------------------------------------------------------
# 5. Rolling one-step-ahead volatility forecasts
# ------------------------------------------------------------

def rolling_garch_forecast(
    full_returns,
    start_idx,
    end_idx,
    family,
    p,
    o,
    q,
    dist,
    rolling_window,
    refit_every=1
):
    """
    Produces one-step-ahead rolling volatility forecasts.

    Forecast at time t uses only information up to t-1.
    """

    forecasts = []
    forecast_index = []

    last_result = None
    last_fit_time = None

    for t in range(start_idx, end_idx):

        window_start = max(0, t - rolling_window)
        estimation_sample = full_returns.iloc[window_start:t]

        should_refit = (
            last_result is None or
            last_fit_time is None or
            (t - last_fit_time) >= refit_every
        )

        if should_refit:
            try:
                last_result = fit_garch_model(
                    returns=estimation_sample,
                    family=family,
                    p=p,
                    o=o,
                    q=q,
                    dist=dist
                )
                last_fit_time = t

            except Exception as e:
                print(f"Rolling estimation failed at t={t} for {family}: {e}")
                forecasts.append(np.nan)
                forecast_index.append(t)
                continue

        try:
            forecast = last_result.forecast(horizon=1, reindex=False)
            variance_forecast = forecast.variance.values[-1, 0]
            volatility_forecast = np.sqrt(max(variance_forecast, 1e-12))

        except Exception as e:
            print(f"Forecast failed at t={t} for {family}: {e}")
            volatility_forecast = np.nan

        forecasts.append(volatility_forecast)
        forecast_index.append(t)

    return pd.Series(forecasts, index=forecast_index)


# ------------------------------------------------------------
# 6. Construct full volatility input series
# ------------------------------------------------------------

ROLLING_WINDOW = len(returns_train)

# Set to 1 for strict rolling re-estimation.
# Use 5 or 10 if computation is slow.
REFIT_EVERY = 1

for family, row in best_by_family.items():

    print(f"\nGenerating volatility input for {family}...")

    # In-sample conditional volatility
    insample_vol = fitted_family_models[family].conditional_volatility

    # Out-of-sample rolling forecasts
    oos_vol = rolling_garch_forecast(
        full_returns=returns,
        start_idx=split_idx,
        end_idx=len(df),
        family=family,
        p=int(row["p"]),
        o=int(row["o"]),
        q=int(row["q"]),
        dist=row["Distribution"],
        rolling_window=ROLLING_WINDOW,
        refit_every=REFIT_EVERY
    )

    full_vol = pd.Series(index=df.index, dtype=float)

    full_vol.iloc[:split_idx] = insample_vol.values
    full_vol.iloc[split_idx:] = oos_vol.reindex(range(split_idx, len(df))).values

    full_vol = full_vol.replace([np.inf, -np.inf], np.nan)
    full_vol = full_vol.ffill().bfill()

    col_name = f"{family.replace('-', '_')}_vol"
    df[col_name] = full_vol

    print(f"Created column: {col_name}")


# ------------------------------------------------------------
# 7. Select best global GARCH-family model according to BIC
# ------------------------------------------------------------

global_best = ic_table.dropna(subset=["BIC"]).sort_values("BIC").iloc[0]
global_family = global_best["Family"]

print("\n============================================================")
print("Global best model according to BIC")
print("============================================================")
print(global_best[["Model", "Family", "p", "o", "q", "Distribution", "AIC", "BIC"]])

selected_col = f"{global_family.replace('-', '_')}_vol"
df["selected_garch_vol"] = df[selected_col]

print(f"\nSelected GARCH volatility column: {selected_col}")



