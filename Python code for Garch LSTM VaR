def qlike_loss(y_true_vol, y_pred_vol):
    """
    QLIKE:
    log(sigma_hat^2) + sigma_proxy^2 / sigma_hat^2
    """
    eps = 1e-10

    true_var = np.maximum(np.asarray(y_true_vol) ** 2, eps)
    pred_var = np.maximum(np.asarray(y_pred_vol) ** 2, eps)

    return np.mean(np.log(pred_var) + true_var / pred_var)


def qlike_series(y_true_vol, y_pred_vol):
    eps = 1e-10

    true_var = np.maximum(np.asarray(y_true_vol) ** 2, eps)
    pred_var = np.maximum(np.asarray(y_pred_vol) ** 2, eps)

    return np.log(pred_var) + true_var / pred_var


