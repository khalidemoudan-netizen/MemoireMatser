print("Period:", var_df["Date"].min().date(), "to", var_df["Date"].max().date())

# ------------------------------------------------------------
# 3. Student-t standardized quantile
# ------------------------------------------------------------

def standardized_student_quantile(alpha, nu):
    q_raw = t.ppf(alpha, df=nu)
    scale = np.sqrt(nu / (nu - 2))
    return q_raw / scale

quantile_rows = []

for confidence, alpha in CONFIDENCE_LEVELS.items():
    q_alpha = standardized_student_quantile(alpha, NU)

    quantile_rows.append({
        "Confidence": confidence,
        "Alpha": alpha,
        "Student_df": NU,
        "Standardized_Student_Quantile": q_alpha
    })

    for model, sigma_col in {
        "GARCH": "Sigma_GARCH",
        "LSTM": "Sigma_LSTM",
        "Hybrid": "Sigma_Hybrid"
    }.items():

        var_col = f"VaR_{model}_{confidence}"
        threshold_col = f"Threshold_{model}_{confidence}"
        violation_col = f"Violation_{model}_{confidence}"

        # Positive VaR as a loss amount
        var_df[var_col] = - (MU + q_alpha * var_df[sigma_col])

        # Return threshold
        var_df[threshold_col] = - var_df[var_col]

        # Violation when realized return is lower than threshold
        var_df[violation_col] = (
            var_df["Return"] < var_df[threshold_col]
        ).astype(int)

quantile_df = pd.DataFrame(quantile_rows)

