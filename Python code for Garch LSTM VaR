# ============================================================
# 3. Test de couverture inconditionnelle de Kupiec
# ============================================================

def kupiec_unconditional_coverage_test(violations, alpha):
    """
    Test de couverture inconditionnelle de Kupiec.

    H0 : le taux empirique de violation est égal au niveau alpha.
    """

    violations = np.asarray(violations).astype(int)

    T = len(violations)
    N = int(violations.sum())
    p_hat = N / T

    eps = 1e-12

    # Log-vraisemblance sous H0
    log_likelihood_null = (
        N * np.log(alpha)
        + (T - N) * np.log(1 - alpha)
    )

    # Log-vraisemblance sous H1
    if N == 0:
        log_likelihood_alt = (T - N) * np.log(max(1 - p_hat, eps))
    elif N == T:
        log_likelihood_alt = N * np.log(max(p_hat, eps))
    else:
        log_likelihood_alt = (
            N * np.log(p_hat)
            + (T - N) * np.log(1 - p_hat)
        )

    LR_UC = -2 * (log_likelihood_null - log_likelihood_alt)

    p_value = 1 - chi2.cdf(LR_UC, df=1)

    return {
        "N_test": T,
        "Observed_Violations": N,
        "Expected_Violations": alpha * T,
        "Violation_Rate": p_hat,
        "LR_UC": LR_UC,
        "p_UC": p_value
    }


# ============================================================
# 4. Test d'indépendance de Christoffersen
# ============================================================

def christoffersen_independence_test(violations):
    """
    Test d'indépendance de Christoffersen.

    H0 : les violations sont indépendantes dans le temps.
    """

    violations = np.asarray(violations).astype(int)

    previous = violations[:-1]
    current = violations[1:]

    n00 = int(((previous == 0) & (current == 0)).sum())
    n01 = int(((previous == 0) & (current == 1)).sum())
    n10 = int(((previous == 1) & (current == 0)).sum())
    n11 = int(((previous == 1) & (current == 1)).sum())

    eps = 1e-12

    # Probabilités conditionnelles
    pi01 = n01 / (n00 + n01) if (n00 + n01) > 0 else 0
    pi11 = n11 / (n10 + n11) if (n10 + n11) > 0 else 0

    # Probabilité commune sous indépendance
    pi = (n01 + n11) / (n00 + n01 + n10 + n11)

    def safe_log(x):
        return np.log(min(max(x, eps), 1 - eps))

    # Log-vraisemblance sous H0 : indépendance
    log_likelihood_independent = (
        (n00 + n10) * safe_log(1 - pi)
        + (n01 + n11) * safe_log(pi)
    )

    # Log-vraisemblance sous H1 : dépendance markovienne
    log_likelihood_dependent = (
        n00 * safe_log(1 - pi01)
        + n01 * safe_log(pi01)
        + n10 * safe_log(1 - pi11)
        + n11 * safe_log(pi11)
    )

    LR_IND = -2 * (
        log_likelihood_independent
        - log_likelihood_dependent
    )

    p_value = 1 - chi2.cdf(LR_IND, df=1)

    return {
        "n00": n00,
        "n01": n01,
        "n10": n10,
        "n11": n11,
        "pi01": pi01,
        "pi11": pi11,
        "LR_IND": LR_IND,
        "p_IND": p_value
    }


# ============================================================
# 5. Test de couverture conditionnelle
# ============================================================

def conditional_coverage_test(LR_UC, LR_IND):
    """
    Test de couverture conditionnelle.

    LR_CC = LR_UC + LR_IND

    H0 : couverture correcte + indépendance des violations.
    """

    LR_CC = LR_UC + LR_IND
    p_value = 1 - chi2.cdf(LR_CC, df=2)

    return {
        "LR_CC": LR_CC,
        "p_CC": p_value
    }


# ============================================================
# 6. Application des tests à tous les modèles
# ============================================================

results = []

for model in MODELS:

    for confidence, alpha in CONFIDENCE_LEVELS.items():

        violation_col = f"Violation_{model}_{confidence}"

        if violation_col not in var_df.columns:
            raise ValueError(
                f"La colonne {violation_col} est absente du fichier VaR."
            )

        violations = var_df[violation_col].values

        # Test Kupiec
        kupiec_result = kupiec_unconditional_coverage_test(
            violations=violations,
            alpha=alpha
        )

        # Test Christoffersen indépendance
        independence_result = christoffersen_independence_test(
            violations=violations
        )

        # Test couverture conditionnelle
        conditional_result = conditional_coverage_test(
            LR_UC=kupiec_result["LR_UC"],
            LR_IND=independence_result["LR_IND"]
        )

        # Décisions statistiques
        decision_uc = (
            "Reject H0"
            if kupiec_result["p_UC"] < SIGNIFICANCE_LEVEL
            else "Do not reject H0"
        )

        decision_ind = (
            "Reject H0"
            if independence_result["p_IND"] < SIGNIFICANCE_LEVEL
            else "Do not reject H0"
        )

        decision_cc = (
            "Reject H0"
            if conditional_result["p_CC"] < SIGNIFICANCE_LEVEL
            else "Do not reject H0"
        )

        results.append({
            "Model": model,
            "Confidence": confidence,
            "Alpha": alpha,
            "N_test": kupiec_result["N_test"],
            "Observed_Violations": kupiec_result["Observed_Violations"],
            "Expected_Violations": kupiec_result["Expected_Violations"],
            "Violation_Rate": kupiec_result["Violation_Rate"],

            "LR_UC": kupiec_result["LR_UC"],
            "p_UC": kupiec_result["p_UC"],
            "Decision_UC": decision_uc,

            "n00": independence_result["n00"],
            "n01": independence_result["n01"],
            "n10": independence_result["n10"],
            "n11": independence_result["n11"],
            "pi01": independence_result["pi01"],
            "pi11": independence_result["pi11"],

            "LR_IND": independence_result["LR_IND"],
            "p_IND": independence_result["p_IND"],
            "Decision_IND": decision_ind,

            "LR_CC": conditional_result["LR_CC"],
            "p_CC": conditional_result["p_CC"],
            "Decision_CC": decision_cc
        })


backtesting_results = pd.DataFrame(results)

