def loss_series(y_true, y_pred, loss="qlike"):
    if loss == "mse":
        return (y_true - y_pred) ** 2

    elif loss == "mae":
        return np.abs(y_true - y_pred)

    elif loss == "qlike":
        return qlike_series(y_true, y_pred)

    else:
        raise ValueError("loss must be 'mse', 'mae', or 'qlike'.")


def diebold_mariano_test(y_true, pred_1, pred_2, loss="qlike"):
    """
    Test de Diebold-Mariano.
    H0 : les deux modèles ont la même précision prédictive.

    d_t = L_1,t - L_2,t

    Si mean(d_t) > 0, le modèle 2 est meilleur que le modèle 1.
    """

    y_true = np.asarray(y_true)
    pred_1 = np.asarray(pred_1)
    pred_2 = np.asarray(pred_2)

    valid = (
        np.isfinite(y_true)
        & np.isfinite(pred_1)
        & np.isfinite(pred_2)
    )

    y_true = y_true[valid]
    pred_1 = pred_1[valid]
    pred_2 = pred_2[valid]

    l1 = loss_series(y_true, pred_1, loss=loss)
    l2 = loss_series(y_true, pred_2, loss=loss)

    d = l1 - l2

    d_mean = np.mean(d)
    d_var = np.var(d, ddof=1)
    n = len(d)

    dm_stat = d_mean / np.sqrt(d_var / n)
    p_value = 2 * (1 - stats.norm.cdf(abs(dm_stat)))

    return {
        "loss": loss,
        "n": n,
        "mean_loss_diff": d_mean,
        "DM_stat": dm_stat,
        "p_value": p_value
    }


