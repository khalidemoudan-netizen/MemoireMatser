            (t - last_fit_t) >= refit_every
        )

        if should_refit:
            try:
                last_result = fit_selected_garch(
                    returns=estimation_sample,
                    family=family,
                    p=p,
                    o=o,
                    q=q,
                    dist=dist
                )
                last_fit_t = t
            except Exception as e:
                print(f"Erreur estimation rolling à t={t}: {e}")
                forecasts.append(np.nan)
                forecast_indices.append(t)
                continue

        try:
            fcast = last_result.forecast(horizon=1, reindex=False)
            forecast_var = fcast.variance.values[-1, 0]
            forecast_vol = np.sqrt(max(forecast_var, 1e-12))
        except Exception as e:
            print(f"Erreur prévision à t={t}: {e}")
            forecast_vol = np.nan

        forecasts.append(forecast_vol)
        forecast_indices.append(t)

    return pd.Series(forecasts, index=forecast_indices)


