DATE_COL = "Date"
PRICE_COL = "Close"

# ------------------------------------------------------------
# 2. Importation des données
# ------------------------------------------------------------

df = pd.read_excel(FILE_PATH, sheet_name=SHEET_NAME, engine="openpyxl")

# Nettoyage des noms de colonnes
