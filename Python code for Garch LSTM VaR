def estimate_garch_family_model(
    returns,
    model_type="GARCH",
    p=1,
    o=0,
    q=1,
    dist="t",
    mean="Constant"
):
    """
    Estime un modèle GARCH-family avec la librairie arch.

    Paramètres :
    ------------
    model_type : str
        "GARCH", "EGARCH" ou "GJR-GARCH"
    p, o, q : int
        Ordres du modèle.
        p : terme ARCH
        o : terme asymétrique
        q : terme GARCH
    dist : str
        Distribution des innovations : "normal" ou "t"
    mean : str
        Spécification de la moyenne : "Constant" par défaut.
    """

    if model_type == "GARCH":
        model = arch_model(
            returns,
            mean=mean,
            vol="GARCH",
            p=p,
            o=0,
            q=q,
            dist=dist,
            rescale=False
        )

    elif model_type == "EGARCH":
        model = arch_model(
            returns,
            mean=mean,
            vol="EGARCH",
            p=p,
            o=o,
            q=q,
            dist=dist,
            rescale=False
        )

    elif model_type == "GJR-GARCH":
        model = arch_model(
            returns,
            mean=mean,
            vol="GARCH",
            p=p,
            o=o,
            q=q,
            dist=dist,
            rescale=False
        )

    else:
        raise ValueError("model_type doit être : 'GARCH', 'EGARCH' ou 'GJR-GARCH'.")

    result = model.fit(disp="off", show_warning=False)

    return result


# ------------------------------------------------------------
# 4. Grille d'estimation des modèles
# ------------------------------------------------------------

P_RANGE = [1, 2]
Q_RANGE = [1, 2]
DISTRIBUTIONS = ["normal", "t"]

